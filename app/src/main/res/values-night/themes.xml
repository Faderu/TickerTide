<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- =====================================================
         DARK THEME (Night Mode)
         Menggunakan palette gelap penuh "Deep Space"
         Memenuhi syarat 2 tema (Light + Dark)
    ====================================================== -->
    <style name="Base.Theme.TickerTide" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Brand Color (sama dengan light) -->
        <item name="colorPrimary">@color/mint_growth</item>
        <item name="colorPrimaryVariant">@color/mint_growth_dim</item>
        <item name="colorOnPrimary">@color/bg_deep_space</item>

        <!-- Secondary Color -->
        <item name="colorSecondary">@color/gold_accent</item>
        <item name="colorOnSecondary">@color/bg_deep_space</item>

        <!-- Error Color -->
        <item name="colorError">@color/crimson_fall</item>

        <!-- Background & Surface (Dark Deep Space) -->
        <item name="android:colorBackground">@color/bg_deep_space</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Bottom Nav -->
        <item name="bottomNavigationStyle">@style/Widget.TickerTide.BottomNav</item>

        <!-- Status Bar (Dark) -->
        <item name="android:statusBarColor">@color/bg_deep_space</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>

    <!-- Main Application Theme (extends Base) -->
    <style name="Theme.TickerTide" parent="Base.Theme.TickerTide" />

    <!-- =====================================================
         SPLASH SCREEN THEME (Dark)
    ====================================================== -->
    <style name="Theme.TickerTide.Splash" parent="Theme.TickerTide">
        <item name="android:windowBackground">@color/bg_deep_space</item>
        <item name="android:statusBarColor">@color/bg_deep_space</item>
        <item name="android:navigationBarColor">@color/bg_deep_space</item>
    </style>

    <!-- =====================================================
         BOTTOM NAVIGATION DARK STYLE
    ====================================================== -->
    <style name="Widget.TickerTide.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface_dark</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- =====================================================
         STOCK CARD STYLE (Dark)
    ====================================================== -->
    <style name="Widget.TickerTide.StockCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_tonal</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- =====================================================
         MATERIAL BUTTON STYLE (Primary Action) - Dark
    ====================================================== -->
    <style name="Widget.TickerTide.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/mint_growth</item>
        <item name="android:textColor">@color/bg_deep_space</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <!-- =====================================================
         TOOLBAR STYLE (Dark)
    ====================================================== -->
    <style name="Widget.TickerTide.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/surface_dark</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="navigationIconTint">@color/text_primary</item>
    </style>

</resources>