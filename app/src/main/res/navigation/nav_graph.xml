<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <!--
        DashboardFragment - Fragment awal (start destination)
        Menampilkan list saham dari API/SQLite
    -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.tickertide.ui.DashboardFragment"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_dashboard">

        <!--
            Action navigasi dari Dashboard ke StockDetail.
            Membawa argument stockSymbol (String) via Safe Args.
            Animasi: slide dari kanan masuk, keluar ke kiri.
        -->
        <action
            android:id="@+id/action_dashboard_to_detail"
            app:destination="@id/stockDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!--
        StockDetailFragment - Fragment detail saham
        Menerima argument stockSymbol dari DashboardFragment
    -->
    <fragment
        android:id="@+id/stockDetailFragment"
        android:name="com.example.tickertide.ui.StockDetailFragment"
        android:label="@string/title_detail"
        tools:layout="@layout/fragment_stock_detail">

        <!-- Safe Args argument: symbol saham yang diklik -->
        <argument
            android:name="stockSymbol"
            app:argType="string" />
    </fragment>

    <!--
        WatchlistFragment - Menampilkan daftar saham yang tersimpan/cache
    -->
    <fragment
        android:id="@+id/nav_watchlist"
        android:name="com.example.tickertide.ui.WatchlistFragment"
        android:label="@string/nav_watchlist"
        tools:layout="@layout/fragment_watchlist">

        <action
            android:id="@+id/action_watchlist_to_detail"
            app:destination="@id/stockDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!--
        PortfolioFragment - Simulasi Trading / Portfolio
    -->
    <fragment
        android:id="@+id/nav_portfolio"
        android:name="com.example.tickertide.ui.PortfolioFragment"
        android:label="Portfolio"
        tools:layout="@layout/fragment_portfolio">

        <action
            android:id="@+id/action_portfolio_to_detail"
            app:destination="@id/stockDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!--
        AlertsFragment - Price Alerts
    -->
    <fragment
        android:id="@+id/nav_alerts"
        android:name="com.example.tickertide.ui.AlertsFragment"
        android:label="Alerts"
        tools:layout="@layout/fragment_alerts">

        <action
            android:id="@+id/action_alerts_to_detail"
            app:destination="@id/stockDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

</navigation>
