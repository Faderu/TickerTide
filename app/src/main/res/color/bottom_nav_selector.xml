<?xml version="1.0" encoding="utf-8"?>
<!-- bottom_nav_selector.xml - Color state list untuk Bottom Navigation items -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State selected (tab aktif) -> mint green -->
    <item android:state_checked="true" android:color="@color/mint_growth" />
    <!-- State default (tab tidak aktif) -> abu-abu secondary -->
    <item android:color="@color/text_secondary" />
</selector>
